# .env.example created
# Project Configuration
PROJECT_NAME=High-Performance WebSocket App
VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_V1_STR=/api/v1

# CORS (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=webapp_db

# TimescaleDB Configuration
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_USER=timescaledb
TIMESCALE_PASSWORD=timescaledb
TIMESCALE_DB=timescaledb

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB Configuration
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=mongodb
MONGODB_PASSWORD=mongodb
MONGODB_DB=test_datasets

# Security
SECRET_KEY=change-this-to-a-secure-random-key-in-production-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_USER=60
RATE_LIMIT_WEBSOCKET_PER_USER=1000

# Real-time Data (1 kHz)
REALTIME_DATA_FREQUENCY_HZ=1000
REALTIME_DOWNSAMPLE_FACTOR=33
REALTIME_BUFFER_SIZE=1000

# Performance
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
WEBSOCKET_MAX_CONNECTIONS=500

# Celery Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2